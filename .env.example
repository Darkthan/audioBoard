PORT=3000
SESSION_SECRET=change-me-in-production

# Compte admin créé au premier démarrage (optionnel).
# Si absent, un assistant de configuration s'affiche à l'adresse /setup.
# ADMIN_USER=admin
# ADMIN_PASSWORD=changez-moi

# Paramètres généraux (surchargent les réglages de l'interface admin au démarrage)
# COMPRESSION_CODEC=mp3
# COMPRESSION_BITRATE=128
# RETENTION_DAYS=30
# WEBRTC_ENABLED=1
# DEFAULT_QUOTA_MB=0

# Connexion par lien email (magic link)
# PASSWORDLESS_ENABLED=0
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=audioboard@example.com

# Clés d'accès WebAuthn / Passkeys
# WEBAUTHN_ENABLED=0
# WEBAUTHN_RP_ID=example.com      # domaine de l'authenticateur (laisser vide = req.hostname)
# WEBAUTHN_RP_NAME=AudioBoard     # nom affiché dans la boîte de dialogue du navigateur
