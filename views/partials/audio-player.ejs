<script>window.AB_WEBRTC = <%= locals.webrtcEnabled !== false ? 'true' : 'false' %>;</script>
<script src="/js/p2p-audio.js"></script>
<!-- ── Sticky bottom player (SoundCloud-style) ──────────────────────────── -->
<div class="sc-player" id="scPlayer">
  <audio id="scAudio" preload="auto"></audio>

  <!-- ── Desktop player ───────────────────────────────────────────────── -->
  <div class="sc-player-inner">
    <div class="sc-left">
      <button class="sc-ctrl-btn" id="scPrevBtn" title="Piste précédente">
        <svg viewBox="0 0 24 24"><path d="M6 6h2v12H6V6zm3.5 6 8.5 6V6L9.5 12z"/></svg>
      </button>
      <button class="sc-play-btn" id="scPlayBtn" title="Lecture / Pause">
        <svg id="scIconPlay" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
        <svg id="scIconPause" viewBox="0 0 24 24" style="display:none"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
      </button>
      <button class="sc-ctrl-btn" id="scNextBtn" title="Piste suivante">
        <svg viewBox="0 0 24 24"><path d="M6 18l8.5-6L6 6v12zm2-8.14L11.03 12 8 14.14V9.86zM16 6h2v12h-2V6z"/></svg>
      </button>
      <div class="sc-track-info">
        <span class="sc-track-name" id="scTrackName">—</span>
        <span class="sc-playlist-name" id="scPlaylistName">—</span>
      </div>
    </div>

    <div class="sc-center">
      <div class="sc-waveform" id="scWaveform">
        <div class="sc-waveform-bars" id="scBars"></div>
      </div>
      <div class="sc-times">
        <span id="scTimeCurrent">0:00</span>
        <span id="scTimeDuration">—</span>
      </div>
    </div>

    <div class="sc-right">
      <button class="sc-ctrl-btn" id="scSpeedBtn" title="Vitesse de lecture" style="font-size:.75rem;font-weight:600;min-width:2.8rem;letter-spacing:-.5px;">1×</button>
      <svg class="sc-vol-icon" id="scVolIcon" viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
        <path id="scVolPath" d="M3 9v6h4l5 5V4L7 9H3zm13.5 3A4.5 4.5 0 0014 7.97v8.05c1.48-.73 2.5-2.25 2.5-4.02z"/>
      </svg>
      <input type="range" class="sc-vol-slider" id="scVolSlider" min="0" max="1" step="0.02" value="1">
    </div>
  </div><!-- /.sc-player-inner -->

  <!-- ── Mini-player (mobile) ──────────────────────────────────────────── -->
  <div class="sc-mini">
    <div class="sc-mini-progress" id="scMiniProgress">
      <div class="sc-mini-fill" id="scMiniFill"></div>
    </div>
    <div class="sc-mini-body">
      <button class="sc-play-btn sc-mini-play" id="scMiniPlayBtn">
        <svg id="scMiniIconPlay" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
        <svg id="scMiniIconPause" viewBox="0 0 24 24" style="display:none"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
      </button>
      <div class="sc-mini-info" id="scMiniExpand">
        <span class="sc-mini-name" id="scMiniName">—</span>
        <span class="sc-mini-pl" id="scMiniPl">—</span>
      </div>
      <button class="sc-mini-expand-btn" id="scMiniExpandBtn" title="Agrandir">
        <svg viewBox="0 0 24 24"><path d="M7 14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12 7h-3v2h5v-5h-2v3zM14 5v2h3v3h2V5h-5z"/></svg>
      </button>
    </div>
  </div>
</div>

<!-- ── Fullscreen player (mobile) ──────────────────────────────────────── -->
<div class="sc-fullscreen" id="scFullscreen">
  <div class="sc-fs-header">
    <button class="sc-fs-close" id="scFsClose" title="Réduire">
      <svg viewBox="0 0 24 24"><path d="M19 11H7.83l4.88-4.88c.39-.39.39-1.03 0-1.42-.39-.39-1.02-.39-1.41 0l-6.59 6.59c-.39.39-.39 1.02 0 1.41l6.59 6.59c.39.39 1.02.39 1.41 0 .39-.39.39-1.02 0-1.41L7.83 13H19c.55 0 1-.45 1-1s-.45-1-1-1z"/></svg>
    </button>
    <div class="sc-fs-meta">
      <span class="sc-fs-pl" id="scFsPl">—</span>
    </div>
  </div>

  <div class="sc-fs-artwork">
    <div class="sc-fs-disc" id="scFsDisc">♪</div>
  </div>

  <div class="sc-fs-info">
    <span class="sc-fs-name" id="scFsName">—</span>
  </div>

  <div class="sc-fs-wave">
    <div class="sc-waveform sc-fs-waveform" id="scFsWaveform">
      <div class="sc-waveform-bars" id="scFsBars"></div>
    </div>
    <div class="sc-times sc-fs-times">
      <span id="scFsTimeCur">0:00</span>
      <span id="scFsTimeDur">—</span>
    </div>
  </div>

  <div class="sc-fs-controls">
    <button class="sc-fs-btn" id="scFsLoopBtn" title="Boucle">
      <svg viewBox="0 0 24 24"><path d="M7 7h10v3l4-4-4-4v3H5v6h2V7zm10 10H7v-3l-4 4 4 4v-3h12v-6h-2v4z"/></svg>
    </button>
    <button class="sc-fs-btn sc-fs-btn-lg" id="scFsPrevBtn" title="Précédent">
      <svg viewBox="0 0 24 24"><path d="M6 6h2v12H6V6zm3.5 6 8.5 6V6L9.5 12z"/></svg>
    </button>
    <button class="sc-play-btn sc-fs-play" id="scFsPlayBtn">
      <svg id="scFsIconPlay" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
      <svg id="scFsIconPause" viewBox="0 0 24 24" style="display:none"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
    </button>
    <button class="sc-fs-btn sc-fs-btn-lg" id="scFsNextBtn" title="Suivant">
      <svg viewBox="0 0 24 24"><path d="M6 18l8.5-6L6 6v12zm2-8.14L11.03 12 8 14.14V9.86zM16 6h2v12h-2V6z"/></svg>
    </button>
    <button class="sc-fs-btn" id="scFsShuffleBtn" title="Aléatoire">
      <svg viewBox="0 0 24 24"><path d="M10.59 9.17 5.41 4 4 5.41l5.17 5.17 1.42-1.41zM14.5 4l2.04 2.04L4 18.59 5.41 20 17.96 7.46 20 9.5V4h-5.5zm.33 9.41-1.41 1.41 3.13 3.13L14.5 20H20v-5.5l-2.04 2.04-3.13-3.13z"/></svg>
    </button>
  </div>
</div>

<script>
(function () {
  const audio       = document.getElementById('scAudio');
  const player      = document.getElementById('scPlayer');

  // Desktop elements
  const playBtn     = document.getElementById('scPlayBtn');
  const prevBtn     = document.getElementById('scPrevBtn');
  const nextBtn     = document.getElementById('scNextBtn');
  const iconPlay    = document.getElementById('scIconPlay');
  const iconPause   = document.getElementById('scIconPause');
  const trackName   = document.getElementById('scTrackName');
  const plName      = document.getElementById('scPlaylistName');
  const timeCur     = document.getElementById('scTimeCurrent');
  const timeDur     = document.getElementById('scTimeDuration');
  const barsEl      = document.getElementById('scBars');
  const waveform    = document.getElementById('scWaveform');
  const volSlider   = document.getElementById('scVolSlider');
  const volPath     = document.getElementById('scVolPath');
  const volIcon     = document.getElementById('scVolIcon');

  // Mini-player elements
  const miniPlayBtn      = document.getElementById('scMiniPlayBtn');
  const miniIconPlay     = document.getElementById('scMiniIconPlay');
  const miniIconPause    = document.getElementById('scMiniIconPause');
  const miniName         = document.getElementById('scMiniName');
  const miniPl           = document.getElementById('scMiniPl');
  const miniFill         = document.getElementById('scMiniFill');
  const miniExpandBtn    = document.getElementById('scMiniExpandBtn');

  // Fullscreen elements
  const fsPanel     = document.getElementById('scFullscreen');
  const fsClose     = document.getElementById('scFsClose');
  const fsPlayBtn   = document.getElementById('scFsPlayBtn');
  const fsPrevBtn   = document.getElementById('scFsPrevBtn');
  const fsNextBtn   = document.getElementById('scFsNextBtn');
  const fsLoopBtn   = document.getElementById('scFsLoopBtn');
  const fsShuffleBtn= document.getElementById('scFsShuffleBtn');
  const fsIconPlay  = document.getElementById('scFsIconPlay');
  const fsIconPause = document.getElementById('scFsIconPause');
  const fsName      = document.getElementById('scFsName');
  const fsPl        = document.getElementById('scFsPl');
  const fsDisc      = document.getElementById('scFsDisc');
  const fsTimeCur   = document.getElementById('scFsTimeCur');
  const fsTimeDur   = document.getElementById('scFsTimeDur');
  const fsBarsEl    = document.getElementById('scFsBars');
  const fsWaveform  = document.getElementById('scFsWaveform');

  const BAR_COUNT = 120;
  const VOL_HIGH = 'M3 9v6h4l5 5V4L7 9H3zm13.5 3A4.5 4.5 0 0014 7.97v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z';
  const VOL_LOW  = 'M18.5 12A4.5 4.5 0 0016 7.97v8.05c1.48-.73 2.5-2.25 2.5-4.02zM5 9v6h4l5 5V4L9 9H5z';
  const VOL_MUTE = 'M16.5 12A4.5 4.5 0 0014 7.97v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z';

  let tracks = [];
  let currentIdx = -1;
  let bars = [], fsBars = [];
  let loopMode = false;
  let shuffleMode = false;
  let currentTrack = null; // always reflects the loaded track regardless of page

  function mimeForCodec(codec) {
    if (codec === 'opus' || codec === 'opus_live') return 'audio/webm';
    if (codec === 'aac') return 'audio/aac';
    return 'audio/mpeg';
  }

  function supportsOpusPlayback() {
    const probe = document.createElement('audio');
    return !!(probe.canPlayType('audio/webm; codecs="opus"') || probe.canPlayType('audio/ogg; codecs="opus"'));
  }

  function buildPlaybackConfig(track) {
    const isOpusSource = track.codec === 'opus' || track.codec === 'opus_live';
    const useMp3Fallback = isOpusSource && !supportsOpusPlayback();
    return {
      streamUrl: useMp3Fallback ? `/stream/${track.token}?transcode=mp3` : `/stream/${track.token}`,
      mime: useMp3Fallback ? 'audio/mpeg' : mimeForCodec(track.codec),
      p2p: !useMp3Fallback,
    };
  }

  let speedIdx  = 0;
  const SPEEDS  = [1, 1.25, 1.5, 2, 0.75];
  const speedBtn = document.getElementById('scSpeedBtn');
  speedBtn.addEventListener('click', () => {
    speedIdx = (speedIdx + 1) % SPEEDS.length;
    audio.playbackRate = SPEEDS[speedIdx];
    speedBtn.textContent = SPEEDS[speedIdx] + '×';
  });

  const STORAGE_KEY = 'sc_state';
  let saveTimer = null;

  // ── State persistence ────────────────────────────────────────────────
  function saveState() {
    if (!currentTrack) return;
    try {
      sessionStorage.setItem(STORAGE_KEY, JSON.stringify({
        token:        currentTrack.token,
        name:         currentTrack.name,
        playlistName: currentTrack.playlistName,
        artist:       currentTrack.artist,
        codec:        currentTrack.codec || 'none',
        currentTime:  audio.currentTime,
        playing:      !audio.paused,
      }));
    } catch {}
  }

  function clearState() {
    sessionStorage.removeItem(STORAGE_KEY);
  }

  function restoreState() {
    try {
      const raw = sessionStorage.getItem(STORAGE_KEY);
      if (!raw) return;
      const state = JSON.parse(raw);
      if (!state.token) return;

      // Find track in current page list (may be -1 on other pages)
      const idx = tracks.findIndex(t => t.token === state.token);
      currentIdx   = idx; // -1 = track not on this page, still playable
      currentTrack = {
        token: state.token,
        name: state.name,
        playlistName: state.playlistName,
        artist: state.artist,
        codec: state.codec || 'none',
      };

      // Populate all UI labels
      updateLabels(currentTrack);

      // Build waveforms
      const seed = state.token.split('').reduce((a, c) => a + c.charCodeAt(0), 0) || 42;
      bars   = buildBars(seed, barsEl);
      fsBars = buildBars(seed, fsBarsEl);

      // Highlight track in list if present on this page
      if (idx !== -1) {
        document.querySelectorAll('[data-sc-token]').forEach(el =>
          el.classList.toggle('sc-active', el.dataset.scToken === state.token)
        );
      }

      player.classList.add('sc-visible');

      audio.addEventListener('canplay', () => {
        audio.currentTime = state.currentTime || 0;
        if (state.playing) audio.play().catch(() => {});
      }, { once: true });

      const playback = buildPlaybackConfig(currentTrack);
      P2PAudio.load(state.token, audio, playback);
    } catch {}
  }

  // ── Register tracks (called by each page, triggers restore) ──────────
  window.scRegisterTracks = function(list) {
    tracks = list;
    restoreState();
  };

  // ── Waveform ─────────────────────────────────────────────────────────
  function buildBars(seed, container) {
    let s = seed;
    function rand() { s = (s * 16807) % 2147483647; return (s - 1) / 2147483646; }
    const heights = Array.from({ length: BAR_COUNT }, (_, i) => {
      const env = Math.sin(Math.PI * i / BAR_COUNT);
      return 0.12 + env * 0.72 * (0.35 + rand() * 0.65);
    });
    container.innerHTML = heights
      .map(h => `<div class="sc-bar" style="height:${Math.round(h * 100)}%"></div>`)
      .join('');
    return container.querySelectorAll('.sc-bar');
  }

  function updateBars(progress, barList) {
    const filled = Math.floor(progress * barList.length);
    barList.forEach((b, i) => b.classList.toggle('sc-bar-played', i < filled));
  }

  // ── Fullscreen open/close ────────────────────────────────────────────
  function openFullscreen() {
    fsPanel.classList.add('sc-fs-open');
    document.body.style.overflow = 'hidden';
  }
  function closeFullscreen() {
    fsPanel.classList.remove('sc-fs-open');
    document.body.style.overflow = '';
  }

  miniExpandBtn.addEventListener('click', openFullscreen);
  document.getElementById('scMiniExpand').addEventListener('click', openFullscreen);
  fsClose.addEventListener('click', closeFullscreen);

  // ── Update all UI labels ──────────────────────────────────────────────
  function updateLabels(t) {
    trackName.textContent = miniName.textContent = fsName.textContent = t.name;
    const sub = [t.artist, t.playlistName].filter(Boolean).join(' · ');
    plName.textContent  = miniPl.textContent = fsPl.textContent = sub;
  }

  // ── Load a track ─────────────────────────────────────────────────────
  function loadTrack(idx, autoplay) {
    if (idx < 0 || idx >= tracks.length) return;
    currentIdx   = idx;
    currentTrack = tracks[idx];

    updateLabels(currentTrack);

    // Waveforms
    const seed = currentTrack.token.split('').reduce((a, c) => a + c.charCodeAt(0), 0) || 42;
    bars   = buildBars(seed, barsEl);
    fsBars = buildBars(seed, fsBarsEl);
    updateBars(0, bars);
    updateBars(0, fsBars);

    // Tenter de charger la vraie waveform depuis l'API
    fetch(`/api/waveform/${currentTrack.token}`)
      .then(r => r.ok ? r.json() : null)
      .then(data => {
        if (!data?.peaks?.length) return;
        const buildFromPeaks = (container) => {
          container.innerHTML = data.peaks
            .map(h => `<div class="sc-bar" style="height:${Math.round(Math.max(0.08, h) * 100)}%"></div>`)
            .join('');
          return container.querySelectorAll('.sc-bar');
        };
        bars   = buildFromPeaks(barsEl);
        fsBars = buildFromPeaks(fsBarsEl);
        if (audio.duration) {
          const p = audio.currentTime / audio.duration;
          updateBars(p, bars);
          updateBars(p, fsBars);
        }
      })
      .catch(() => {});

    // Disc animation reset
    fsDisc.style.animation = 'none';
    fsDisc.offsetHeight; // reflow
    fsDisc.style.animation = '';

    // Highlight active track
    document.querySelectorAll('[data-sc-token]').forEach(el =>
      el.classList.toggle('sc-active', el.dataset.scToken === currentTrack.token)
    );

    // Load audio (P2P si dispo, sinon HTTP direct)
    timeDur.textContent = fsTimeDur.textContent = '—';
    timeCur.textContent = fsTimeCur.textContent = '0:00';
    miniFill.style.width = '0%';
    player.classList.add('sc-visible');
    const playback = buildPlaybackConfig(currentTrack);
    P2PAudio.load(currentTrack.token, audio, playback).then(() => {
      if (autoplay) audio.play().catch(() => {});
    });
  }

  // ── Public API ───────────────────────────────────────────────────────
  window.scPlay = function(token) {
    const idx = tracks.findIndex(t => t.token === token);
    if (idx === -1) return;
    if (idx === currentIdx && !audio.paused) { audio.pause(); return; }
    loadTrack(idx, true);
  };

  // ── Next track logic ─────────────────────────────────────────────────
  function playNext() {
    if (shuffleMode) {
      let idx;
      do { idx = Math.floor(Math.random() * tracks.length); } while (idx === currentIdx && tracks.length > 1);
      loadTrack(idx, true);
    } else {
      loadTrack(currentIdx + 1 < tracks.length ? currentIdx + 1 : 0, true);
    }
  }

  function playPrev() {
    if (audio.currentTime > 3) { audio.currentTime = 0; return; }
    loadTrack(currentIdx - 1 >= 0 ? currentIdx - 1 : tracks.length - 1, true);
  }

  // ── Controls ─────────────────────────────────────────────────────────
  function togglePlay() {
    if (currentIdx === -1 && tracks.length) { loadTrack(0, true); return; }
    if (audio.paused) audio.play().catch(() => {});
    else audio.pause();
  }

  playBtn.addEventListener('click', togglePlay);
  miniPlayBtn.addEventListener('click', togglePlay);
  fsPlayBtn.addEventListener('click', togglePlay);

  prevBtn.addEventListener('click', playPrev);
  fsPrevBtn.addEventListener('click', playPrev);
  nextBtn.addEventListener('click', playNext);
  fsNextBtn.addEventListener('click', playNext);

  fsLoopBtn.addEventListener('click', () => {
    loopMode = !loopMode;
    fsLoopBtn.classList.toggle('sc-fs-btn-active', loopMode);
  });

  fsShuffleBtn.addEventListener('click', () => {
    shuffleMode = !shuffleMode;
    fsShuffleBtn.classList.toggle('sc-fs-btn-active', shuffleMode);
  });

  // ── Seek ─────────────────────────────────────────────────────────────
  function seekByClick(e) {
    if (!audio.duration) return;
    const rect = e.currentTarget.getBoundingClientRect();
    const ratio = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
    audio.currentTime = ratio * audio.duration;
  }

  waveform.addEventListener('click', seekByClick);
  fsWaveform.addEventListener('click', seekByClick);
  document.getElementById('scMiniProgress').addEventListener('click', seekByClick);

  // ── Audio events ─────────────────────────────────────────────────────
  function fmt(s) {
    if (!isFinite(s)) return '—';
    return Math.floor(s / 60) + ':' + String(Math.floor(s % 60)).padStart(2, '0');
  }

  function setPlayingState(playing) {
    iconPlay.style.display  = miniIconPlay.style.display  = fsIconPlay.style.display  = playing ? 'none' : '';
    iconPause.style.display = miniIconPause.style.display = fsIconPause.style.display = playing ? '' : 'none';
    fsDisc.classList.toggle('spinning', playing);
  }

  audio.addEventListener('loadedmetadata', () => {
    timeDur.textContent = fsTimeDur.textContent = fmt(audio.duration);
  });
  audio.addEventListener('timeupdate', () => {
    const cur = fmt(audio.currentTime);
    timeCur.textContent = fsTimeCur.textContent = cur;
    if (audio.duration) {
      const p = audio.currentTime / audio.duration;
      updateBars(p, bars);
      updateBars(p, fsBars);
      miniFill.style.width = (p * 100) + '%';
    }
    // Throttle saves to every 2s
    clearTimeout(saveTimer);
    saveTimer = setTimeout(saveState, 2000);
  });
  audio.addEventListener('play', () => {
    setPlayingState(true);
    saveState();
    if (currentTrack && !audio._scTracked) {
      audio._scTracked = true;
      fetch(`/api/play/${currentTrack.token}`, { method: 'POST' }).catch(() => {});
    }
  });
  audio.addEventListener('pause', () => { setPlayingState(false); saveState(); });
  audio.addEventListener('ended', () => {
    audio._scTracked = false;
    if (loopMode) { audio.currentTime = 0; audio.play().catch(() => {}); }
    else if (tracks.length > 0 && (currentIdx + 1 < tracks.length || shuffleMode)) playNext();
    else { updateBars(0, bars); updateBars(0, fsBars); setPlayingState(false); clearState(); }
  });

  // ── Volume ───────────────────────────────────────────────────────────
  volSlider.addEventListener('input', () => {
    audio.volume = volSlider.value;
    const v = parseFloat(volSlider.value);
    volPath.setAttribute('d', v === 0 ? VOL_MUTE : v < 0.5 ? VOL_LOW : VOL_HIGH);
  });
  volIcon.addEventListener('click', () => {
    if (audio.volume > 0) { audio.volume = 0; volSlider.value = 0; volPath.setAttribute('d', VOL_MUTE); }
    else { audio.volume = 1; volSlider.value = 1; volPath.setAttribute('d', VOL_HIGH); }
  });
})();
</script>

<script>
if ('serviceWorker' in navigator) {
  window.addEventListener('load', () =>
    navigator.serviceWorker.register('/sw.js').catch(() => {})
  );
}
</script>
