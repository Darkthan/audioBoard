<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AudioBoard</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container">
    <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

    <% if (locals.quotaMb > 0) {
      const pct = Math.min(100, Math.round(locals.storageUsed / (locals.quotaMb * 1048576) * 100));
    %>
    <div class="card" style="margin-bottom:1.5rem; padding:.75rem 1rem;">
      <div style="display:flex; justify-content:space-between; font-size:.85rem; margin-bottom:.4rem;">
        <span>Espace utilisé</span>
        <span class="text-muted"><%= (locals.storageUsed/1048576).toFixed(1) %> Mo / <%= locals.quotaMb %> Mo (<%= pct %>%)</span>
      </div>
      <div style="background:var(--border); border-radius:4px; height:6px; overflow:hidden;">
        <div style="width:<%= pct %>%; background:<%= pct>=90?'var(--danger)':pct>=70?'var(--warning)':'var(--primary)' %>; height:100%; transition:width .3s;"></div>
      </div>
    </div>
    <% } %>

    <div class="dashboard-header">
      <h1>Mes playlists</h1>
      <form method="POST" action="/playlists" class="new-playlist-form">
        <input type="text" name="name" class="form-control" placeholder="Nom de la nouvelle playlist" required>
        <button type="submit" class="btn btn-primary">Créer</button>
      </form>
    </div>

    <% if (!playlists.length) { %>
      <div class="empty-state">
        <div class="empty-state-icon">🎵</div>
        <p>Aucune playlist pour le moment.</p>
        <p class="text-muted text-sm">Créez votre première playlist ci-dessus.</p>
      </div>
    <% } else { %>
      <div class="playlist-grid">
        <% playlists.forEach(p => { %>
          <a href="/playlists/<%= p.id %>" class="playlist-card">
            <div class="playlist-card-icon">♪</div>
            <div class="playlist-card-body">
              <div class="playlist-card-name"><%= p.name %></div>
              <div class="playlist-card-meta">
                <% if (p.owner_name) { %><span><%= p.owner_name %></span> &middot; <% } %>
                <span><%= p.file_count %> piste<%= p.file_count !== 1 ? 's' : '' %></span>
                <% if (p.share_token) { %> &middot; <span class="badge-shared">Partagé</span><% } %>
              </div>
            </div>
            <div class="playlist-card-arrow">›</div>
          </a>
        <% }) %>
      </div>
    <% } %>

    <!-- Liens d'enregistrement -->
    <div style="margin-top:2.5rem;">
      <div class="dashboard-header">
        <h2 style="font-size:1.15rem; margin:0;">Liens d'enregistrement</h2>
        <form method="POST" action="/record-links" class="new-playlist-form">
          <input type="text" name="name" class="form-control" placeholder="Nom du lien (ex : Exercice 1)" required maxlength="100">
          <button type="submit" class="btn btn-primary">Créer</button>
        </form>
      </div>

      <% if (!recordLinks.length) { %>
        <div class="empty-state" style="padding:1.25rem 1rem;">
          <p>Aucun lien d'enregistrement.</p>
          <p class="text-muted text-sm">Créez un lien à partager pour collecter des enregistrements audio.</p>
        </div>
      <% } else { %>
        <div style="display:flex; flex-direction:column; gap:.6rem; margin-top:.75rem;">
          <% recordLinks.forEach(rl => { %>
            <div class="card" style="padding:.85rem 1rem; display:flex; align-items:center; gap:.75rem; flex-wrap:wrap;">
              <div style="flex:1; min-width:0;">
                <div style="font-weight:600; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"><%= rl.name %></div>
                <div class="text-muted" style="font-size:.8rem; margin-top:.15rem;">
                  <%= rl.recording_count %> enregistrement<%= rl.recording_count !== 1 ? 's' : '' %>
                  <% if (rl.playlist_id) { %>
                    &middot; <a href="/playlists/<%= rl.playlist_id %>" style="color:var(--primary);">Écouter / télécharger</a>
                  <% } %>
                </div>
              </div>
              <div style="display:flex; gap:.4rem; flex-shrink:0; flex-wrap:wrap;">
                <button class="copy-btn" onclick="copyRecordLink('<%= rl.token %>', this)">Copier le lien</button>
                <form method="POST" action="/record-links/<%= rl.id %>/delete"
                      onsubmit="return confirm('Supprimer ce lien d\'enregistrement ?\n\nLes enregistrements déjà reçus resteront dans la playlist associée.')">
                  <button type="submit" class="copy-btn" style="color:var(--danger);">Supprimer</button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>

  <script>
    function copyRecordLink(token, btn) {
      const url = window.location.origin + '/record/' + token;
      navigator.clipboard.writeText(url).then(() => {
        const orig = btn.textContent;
        btn.textContent = 'Copié !';
        setTimeout(() => btn.textContent = orig, 2000);
      }).catch(() => {
        prompt('Copiez ce lien :', url);
      });
    }
  </script>
</body>
</html>
