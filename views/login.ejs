<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AudioBoard - Connexion</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="login-container">
    <div class="login-box">
      <h1>AudioBoard</h1>
      <p class="subtitle">Connectez-vous pour continuer</p>

      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>
      <% if (info) { %>
        <div class="alert alert-info"><%= info %></div>
      <% } %>

      <!-- ── Clé d'accès (WebAuthn) ──────────────────────────────────────── -->
      <div id="webauthnSection" style="margin-bottom:1rem;">
        <div class="form-group" style="margin-bottom:.5rem;">
          <label for="waUsername">Nom d'utilisateur</label>
          <input type="text" id="waUsername" class="form-control" autocomplete="username"
                 placeholder="Votre identifiant">
        </div>
        <button type="button" id="webauthnBtn" class="btn btn-secondary" style="width:100%; justify-content:center;">
          🔑 Se connecter avec une clé d'accès
        </button>
        <div id="waError" class="alert alert-error" style="display:none; margin-top:.5rem;"></div>
      </div>

      <div style="text-align:center; margin:.75rem 0; color:var(--text-muted); font-size:.85rem;">— ou —</div>

      <% if (locals.passwordlessEnabled) { %>
        <!-- ── Formulaire magic link ─────────────────────────────────── -->
        <form method="POST" action="/login/magic" id="formMagic">
          <div class="form-group">
            <label for="username">Nom d'utilisateur</label>
            <input type="text" id="username" name="username" class="form-control" required autofocus>
          </div>
          <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center;">
            Recevoir un lien de connexion
          </button>
        </form>

        <div style="text-align:center; margin:1rem 0; color:var(--text-muted); font-size:.85rem;">
          — ou —
        </div>

        <!-- ── Toggle mot de passe ───────────────────────────────────── -->
        <div id="passwordSection" style="display:none;">
          <form method="POST" action="/login">
            <div class="form-group">
              <label for="username2">Nom d'utilisateur</label>
              <input type="text" id="username2" name="username" class="form-control" required>
            </div>
            <div class="form-group">
              <label for="password">Mot de passe</label>
              <input type="password" id="password" name="password" class="form-control" required autofocus>
            </div>
            <button type="submit" class="btn btn-secondary" style="width:100%; justify-content:center;">
              Se connecter avec un mot de passe
            </button>
          </form>
        </div>

        <button type="button" id="togglePassword" onclick="togglePasswordForm()"
                style="background:none; border:none; color:var(--primary); cursor:pointer; width:100%; margin-top:.5rem; font-size:.875rem; text-decoration:underline;">
          Se connecter avec un mot de passe
        </button>

        <script>
          function togglePasswordForm() {
            const sec = document.getElementById('passwordSection');
            const btn = document.getElementById('togglePassword');
            const open = sec.style.display === 'none';
            sec.style.display = open ? '' : 'none';
            btn.textContent = open ? 'Annuler' : 'Se connecter avec un mot de passe';
            if (open) {
              // Sync username
              const u = document.getElementById('username').value;
              if (u) document.getElementById('username2').value = u;
              document.getElementById('password').focus();
            }
          }
        </script>
      <% } else { %>
        <!-- ── Formulaire mot de passe classique ─────────────────────── -->
        <form method="POST" action="/login">
          <div class="form-group">
            <label for="username">Nom d'utilisateur</label>
            <input type="text" id="username" name="username" class="form-control" required autofocus>
          </div>
          <div class="form-group">
            <label for="password">Mot de passe</label>
            <input type="password" id="password" name="password" class="form-control" required>
          </div>
          <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center; margin-top:0.5rem;">
            Se connecter
          </button>
        </form>
      <% } %>
    </div>
  </div>

  <script>
    function b64urlToBuffer(b64url) {
      const b64 = b64url.replace(/-/g, '+').replace(/_/g, '/').padEnd(
        b64url.length + (4 - b64url.length % 4) % 4, '=');
      return Uint8Array.from(atob(b64), c => c.charCodeAt(0)).buffer;
    }
    function bufferToB64url(buf) {
      return btoa(String.fromCharCode(...new Uint8Array(buf)))
        .replace(/\+/g, '-').replace(/\//g, '_').replace(/=/g, '');
    }

    document.getElementById('webauthnBtn')?.addEventListener('click', async () => {
      const username = document.getElementById('waUsername').value.trim();
      const errEl    = document.getElementById('waError');
      errEl.style.display = 'none';

      if (!username) { errEl.textContent = 'Entrez votre nom d\'utilisateur.'; errEl.style.display = ''; return; }
      if (!window.PublicKeyCredential) { errEl.textContent = 'Navigateur non supporté.'; errEl.style.display = ''; return; }

      try {
        const optsRes = await fetch('/login/webauthn/start', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username }),
        });
        const opts = await optsRes.json();
        if (opts.error) { errEl.textContent = opts.error; errEl.style.display = ''; return; }

        opts.challenge = b64urlToBuffer(opts.challenge);
        if (opts.allowCredentials)
          opts.allowCredentials = opts.allowCredentials.map(c => ({ ...c, id: b64urlToBuffer(c.id) }));

        const assertion = await navigator.credentials.get({ publicKey: opts });
        if (!assertion) { errEl.textContent = 'Authentification annulée.'; errEl.style.display = ''; return; }

        const assertionResponse = {
          id: assertion.id,
          rawId: bufferToB64url(assertion.rawId),
          response: {
            clientDataJSON:    bufferToB64url(assertion.response.clientDataJSON),
            authenticatorData: bufferToB64url(assertion.response.authenticatorData),
            signature:         bufferToB64url(assertion.response.signature),
            userHandle: assertion.response.userHandle ? bufferToB64url(assertion.response.userHandle) : null,
          },
          clientExtensionResults: assertion.getClientExtensionResults(),
          type: assertion.type,
        };

        const finishRes = await fetch('/login/webauthn/finish', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(assertionResponse),
        });
        const result = await finishRes.json();
        if (result.ok) window.location.href = result.redirect || '/';
        else { errEl.textContent = result.error || 'Authentification échouée.'; errEl.style.display = ''; }
      } catch (err) {
        errEl.textContent = 'Erreur : ' + err.message;
        errEl.style.display = '';
      }
    });

    // Sync du champ username vers le champ WebAuthn
    document.querySelectorAll('input[name="username"]').forEach(inp => {
      inp.addEventListener('input', () => {
        const waInput = document.getElementById('waUsername');
        if (waInput && !waInput.value) waInput.value = inp.value;
      });
    });
  </script>
</body>
</html>
