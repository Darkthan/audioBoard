<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AudioBoard - Connexion</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="login-container">
    <div class="login-box">
      <h1>AudioBoard</h1>
      <p class="subtitle">Connectez-vous pour continuer</p>

      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>
      <% if (info) { %>
        <div class="alert alert-info"><%= info %></div>
      <% } %>

      <!-- ── Étape 1 : identifiant ─────────────────────────────────────────── -->
      <div id="step1">
        <div class="form-group">
          <label for="usernameInput">Nom d'utilisateur</label>
          <input type="text" id="usernameInput" class="form-control"
                 autocomplete="username" autofocus placeholder="Votre identifiant">
        </div>
        <button type="button" id="continueBtn" class="btn btn-primary"
                style="width:100%; justify-content:center;">
          Continuer →
        </button>

        <% if (locals.webauthnEnabled) { %>
        <div style="margin-top:1.5rem; padding-top:1.25rem; border-top:1px solid var(--border);">
          <p class="text-muted text-sm" style="text-align:center; margin:0 0 .75rem;">
            Ou connectez-vous sans mot de passe :
          </p>
          <button type="button" id="webauthnBtn" class="btn btn-secondary"
                  style="width:100%; justify-content:center;">
            🔑 Se connecter avec une clé d'accès
          </button>
          <div id="waError" class="alert alert-error" style="display:none; margin-top:.5rem;"></div>
        </div>
        <% } %>
      </div>

      <!-- ── Étape 2 : mot de passe (et magic link si dispo) ──────────────── -->
      <div id="step2" style="display:none;">
        <div style="display:flex; align-items:center; gap:.75rem; margin-bottom:1.25rem;">
          <button type="button" onclick="goBack()"
                  style="background:none; border:none; cursor:pointer; color:var(--primary);
                         font-size:1.1rem; padding:0; line-height:1;" aria-label="Retour">←</button>
          <span id="usernameDisplay"
                style="font-weight:500; color:var(--text); font-size:.95rem;
                       overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"></span>
        </div>

        <form method="POST" action="/login" id="formPassword">
          <input type="hidden" name="username" id="hiddenUsername">
          <div class="form-group">
            <label for="password">Mot de passe</label>
            <input type="password" id="password" name="password" class="form-control"
                   required autocomplete="current-password">
          </div>
          <button type="submit" class="btn btn-primary"
                  style="width:100%; justify-content:center;">
            Se connecter
          </button>
        </form>

        <% if (locals.passwordlessEnabled) { %>
        <div style="text-align:center; margin:1rem 0; color:var(--text-muted); font-size:.85rem;">
          — ou —
        </div>
        <div id="magicLinkSection">
          <input type="hidden" id="hiddenUsernameMagic">
          <button type="button" id="magicLinkBtn" class="btn btn-secondary"
                  style="width:100%; justify-content:center;">
            Recevoir un lien de connexion
          </button>
        </div>
        <div id="magicLinkWaiting" style="display:none; text-align:center; padding:.75rem 0;">
          <div class="text-muted text-sm" style="margin-bottom:.5rem;">
            Lien envoyé — en attente de validation…
          </div>
          <div id="magicLinkError" class="alert alert-error" style="display:none;"></div>
        </div>
        <% } %>
      </div>

    </div>
  </div>

  <script>
    // ── Navigation entre étapes ───────────────────────────────────────────────
    const prefill = '<%= (locals.prefillUsername || "").replace(/'/g, "\\'") %>';

    function goToStep2(username) {
      document.getElementById('usernameDisplay').textContent = username;
      document.getElementById('hiddenUsername').value = username;
      const magicInput = document.getElementById('hiddenUsernameMagic');
      if (magicInput) magicInput.value = username;
      document.getElementById('step1').style.display = 'none';
      document.getElementById('step2').style.display = '';
      document.getElementById('password').focus();
      stopMagicPoll(); // annuler un éventuel poll en cours si on revient en arrière
    }

    function goBack() {
      document.getElementById('step2').style.display = 'none';
      document.getElementById('step1').style.display = '';
      document.getElementById('usernameInput').focus();
    }

    document.getElementById('continueBtn').addEventListener('click', () => {
      const username = document.getElementById('usernameInput').value.trim();
      if (!username) { document.getElementById('usernameInput').focus(); return; }
      goToStep2(username);
    });

    document.getElementById('usernameInput').addEventListener('keydown', e => {
      if (e.key === 'Enter') document.getElementById('continueBtn').click();
    });

    // Si erreur de mot de passe côté serveur, aller directement à l'étape 2
    if (prefill) {
      document.getElementById('usernameInput').value = prefill;
      goToStep2(prefill);
    }

    // ── Magic link (cross-device) ─────────────────────────────────────────────
    let magicPollTimer = null;

    function stopMagicPoll() {
      if (magicPollTimer) { clearInterval(magicPollTimer); magicPollTimer = null; }
    }

    function startMagicPoll() {
      stopMagicPoll();
      magicPollTimer = setInterval(async () => {
        try {
          const r = await fetch('/login/magic/poll');
          const d = await r.json();
          if (d.ok) {
            stopMagicPoll();
            window.location.href = '/';
          } else if (d.expired) {
            stopMagicPoll();
            const errEl = document.getElementById('magicLinkError');
            if (errEl) { errEl.textContent = 'Le lien a expiré. Veuillez en demander un nouveau.'; errEl.style.display = ''; }
          }
        } catch { /* réseau indisponible, on réessaie au prochain tick */ }
      }, 2000);
    }

    document.getElementById('magicLinkBtn')?.addEventListener('click', async () => {
      const username = document.getElementById('hiddenUsernameMagic')?.value || '';
      const btn = document.getElementById('magicLinkBtn');
      btn.disabled = true;
      const errEl = document.getElementById('magicLinkError');
      if (errEl) errEl.style.display = 'none';

      try {
        const r = await fetch('/login/magic', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: 'username=' + encodeURIComponent(username),
        });
        const d = await r.json();
        if (d.error) {
          btn.disabled = false;
          if (errEl) { errEl.textContent = d.error; errEl.style.display = ''; }
          return;
        }
        // Afficher l'état d'attente et démarrer le polling
        document.getElementById('magicLinkSection').style.display = 'none';
        document.getElementById('magicLinkWaiting').style.display = '';
        startMagicPoll();
      } catch {
        btn.disabled = false;
        if (errEl) { errEl.textContent = 'Erreur réseau. Réessayez.'; errEl.style.display = ''; }
      }
    });

    // ── WebAuthn ──────────────────────────────────────────────────────────────
    function b64urlToBuffer(b64url) {
      const b64 = b64url.replace(/-/g, '+').replace(/_/g, '/').padEnd(
        b64url.length + (4 - b64url.length % 4) % 4, '=');
      return Uint8Array.from(atob(b64), c => c.charCodeAt(0)).buffer;
    }
    function bufferToB64url(buf) {
      return btoa(String.fromCharCode(...new Uint8Array(buf)))
        .replace(/\+/g, '-').replace(/\//g, '_').replace(/=/g, '');
    }

    document.getElementById('webauthnBtn')?.addEventListener('click', async () => {
      const errEl = document.getElementById('waError');
      errEl.style.display = 'none';

      if (!window.PublicKeyCredential) {
        errEl.textContent = 'Navigateur non supporté.';
        errEl.style.display = '';
        return;
      }

      try {
        const optsRes = await fetch('/login/webauthn/start', {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}',
        });
        const opts = await optsRes.json();
        if (opts.error) { errEl.textContent = opts.error; errEl.style.display = ''; return; }

        opts.challenge = b64urlToBuffer(opts.challenge);
        if (opts.allowCredentials)
          opts.allowCredentials = opts.allowCredentials.map(c => ({ ...c, id: b64urlToBuffer(c.id) }));

        const assertion = await navigator.credentials.get({ publicKey: opts });
        if (!assertion) { errEl.textContent = 'Authentification annulée.'; errEl.style.display = ''; return; }

        const assertionResponse = {
          id: assertion.id,
          rawId: bufferToB64url(assertion.rawId),
          response: {
            clientDataJSON:    bufferToB64url(assertion.response.clientDataJSON),
            authenticatorData: bufferToB64url(assertion.response.authenticatorData),
            signature:         bufferToB64url(assertion.response.signature),
            userHandle: assertion.response.userHandle ? bufferToB64url(assertion.response.userHandle) : null,
          },
          clientExtensionResults: assertion.getClientExtensionResults(),
          type: assertion.type,
        };

        const finishRes = await fetch('/login/webauthn/finish', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(assertionResponse),
        });
        const result = await finishRes.json();
        if (result.ok) window.location.href = result.redirect || '/';
        else { errEl.textContent = result.error || 'Authentification échouée.'; errEl.style.display = ''; }
      } catch (err) {
        errEl.textContent = 'Erreur : ' + err.message;
        errEl.style.display = '';
      }
    });
  </script>
</body>
</html>
