<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title><%= file.original_name %></title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .player-wrap {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }

    .player-card {
      width: 100%;
      max-width: 580px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 2.5rem 2.5rem 2rem;
      box-shadow: 0 40px 80px rgba(0,0,0,0.45);
    }

    /* Meta */
    .player-meta {
      font-size: 0.75rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 0.5rem;
    }

    .player-title {
      font-size: 1.35rem;
      font-weight: 700;
      line-height: 1.25;
      word-break: break-word;
      margin-bottom: 2rem;
    }

    /* Waveform */
    .waveform-wrap {
      position: relative;
      height: 64px;
      margin-bottom: 0.5rem;
      cursor: pointer;
    }

    .waveform-bars {
      display: flex;
      align-items: center;
      gap: 2px;
      height: 100%;
      overflow: hidden;
    }

    .waveform-bars .bar {
      flex: 1;
      border-radius: 2px;
      background: var(--border);
      transition: background 0.05s;
      min-width: 2px;
    }

    .waveform-bars .bar.played {
      background: var(--primary);
    }

    /* Seeker ghost overlay */
    .waveform-wrap::after {
      content: '';
      position: absolute;
      inset: 0;
    }

    /* Times */
    .player-times {
      display: flex;
      justify-content: space-between;
      font-size: 0.75rem;
      color: var(--text-muted);
      margin-bottom: 1.75rem;
      font-variant-numeric: tabular-nums;
    }

    /* Controls */
    .player-controls {
      display: flex;
      align-items: center;
      gap: 1.25rem;
    }

    .play-btn {
      width: 56px;
      height: 56px;
      border-radius: 50%;
      background: var(--primary);
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: background 0.15s, transform 0.1s;
      box-shadow: 0 4px 20px rgba(232, 93, 4, 0.45);
    }

    .play-btn:hover { background: var(--primary-dark); transform: scale(1.05); }
    .play-btn:active { transform: scale(0.97); }

    .play-btn svg {
      width: 22px;
      height: 22px;
      fill: #fff;
    }

    /* Volume */
    .volume-group {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-left: auto;
    }

    .volume-icon {
      color: var(--text-muted);
      flex-shrink: 0;
      cursor: pointer;
    }

    .volume-slider {
      -webkit-appearance: none;
      appearance: none;
      width: 80px;
      height: 4px;
      border-radius: 2px;
      background: var(--border);
      outline: none;
      cursor: pointer;
    }

    .volume-slider::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 13px;
      height: 13px;
      border-radius: 50%;
      background: var(--primary);
      cursor: pointer;
    }

    .volume-slider::-moz-range-thumb {
      width: 13px;
      height: 13px;
      border: none;
      border-radius: 50%;
      background: var(--primary);
      cursor: pointer;
    }

    /* Loading state */
    .player-card.loading .play-btn {
      opacity: 0.6;
      cursor: wait;
    }

    @media (max-width: 480px) {
      .player-card { padding: 1.75rem 1.25rem 1.5rem; }
      .volume-slider { width: 60px; }
    }
  </style>
</head>
<body>
  <div class="player-wrap">
    <div class="player-card loading" id="playerCard">

      <div class="player-meta">
        <%= file.playlist_name || 'AudioBoard' %>
        <% if (file.expires_at) { %>
          &nbsp;·&nbsp;Expire le <%= new Date(file.expires_at).toLocaleDateString('fr-FR') %>
        <% } %>
      </div>

      <div class="player-title"><%= file.original_name %></div>

      <!-- Waveform -->
      <div class="waveform-wrap" id="waveformWrap">
        <div class="waveform-bars" id="waveformBars"></div>
      </div>

      <!-- Times -->
      <div class="player-times">
        <span id="timeCurrent">0:00</span>
        <span id="timeDuration">—</span>
      </div>

      <!-- Controls -->
      <div class="player-controls">
        <!-- Play / Pause -->
        <button class="play-btn" id="playBtn" title="Lecture / Pause">
          <!-- Play icon (default) -->
          <svg id="iconPlay" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
          <!-- Pause icon (hidden) -->
          <svg id="iconPause" viewBox="0 0 24 24" style="display:none;"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
        </button>

        <!-- Volume -->
        <div class="volume-group">
          <svg class="volume-icon" id="volIcon" viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
            <path id="volPath" d="M3 9v6h4l5 5V4L7 9H3zm13.5 3A4.5 4.5 0 0014 7.97v8.05c1.48-.73 2.5-2.25 2.5-4.02z"/>
          </svg>
          <input type="range" class="volume-slider" id="volSlider" min="0" max="1" step="0.02" value="1">
        </div>
      </div>

      <!-- Hidden audio element -->
      <audio id="audio" preload="auto" data-token="<%= file.share_token %>" data-codec="<%= file.codec || 'none' %>"></audio>
    </div>
  </div>

  <script>
    const audio     = document.getElementById('audio');
    const playBtn   = document.getElementById('playBtn');
    const iconPlay  = document.getElementById('iconPlay');
    const iconPause = document.getElementById('iconPause');
    const timeCurrent = document.getElementById('timeCurrent');
    const timeDuration = document.getElementById('timeDuration');
    const waveformWrap = document.getElementById('waveformWrap');
    const barsContainer = document.getElementById('waveformBars');
    const volSlider = document.getElementById('volSlider');
    const volPath   = document.getElementById('volPath');
    const card      = document.getElementById('playerCard');

    // ── Generate fake waveform bars ──────────────────────────────────────────
    const BAR_COUNT = 80;
    const heights = [];
    // Seeded pseudo-random for stable appearance on reload
    let seed = 42;
    function rand() { seed = (seed * 16807 + 0) % 2147483647; return (seed - 1) / 2147483646; }
    for (let i = 0; i < BAR_COUNT; i++) {
      // Envelope: quieter at start/end, louder in middle
      const env = Math.sin(Math.PI * i / BAR_COUNT);
      heights.push(0.15 + env * 0.7 * (0.4 + rand() * 0.6));
    }

    barsContainer.innerHTML = heights.map((h, i) =>
      `<div class="bar" data-i="${i}" style="height:${Math.round(h * 100)}%"></div>`
    ).join('');

    const bars = barsContainer.querySelectorAll('.bar');

    function updateBars(progress) {
      const filled = Math.floor(progress * BAR_COUNT);
      bars.forEach((b, i) => b.classList.toggle('played', i < filled));
    }

    // ── Seek on waveform click ───────────────────────────────────────────────
    waveformWrap.addEventListener('click', e => {
      if (!audio.duration) return;
      const rect = waveformWrap.getBoundingClientRect();
      const ratio = (e.clientX - rect.left) / rect.width;
      audio.currentTime = ratio * audio.duration;
    });

    // ── Format time mm:ss ────────────────────────────────────────────────────
    function fmt(s) {
      if (!isFinite(s)) return '—';
      const m = Math.floor(s / 60);
      return m + ':' + String(Math.floor(s % 60)).padStart(2, '0');
    }

    // ── Audio events ─────────────────────────────────────────────────────────
    audio.addEventListener('canplay', () => card.classList.remove('loading'));

    audio.addEventListener('loadedmetadata', () => {
      timeDuration.textContent = fmt(audio.duration);
    });

    audio.addEventListener('timeupdate', () => {
      timeCurrent.textContent = fmt(audio.currentTime);
      if (audio.duration) updateBars(audio.currentTime / audio.duration);
    });

    audio.addEventListener('play',  () => { iconPlay.style.display='none';  iconPause.style.display=''; });
    audio.addEventListener('pause', () => { iconPlay.style.display='';     iconPause.style.display='none'; });
    audio.addEventListener('ended', () => { updateBars(0); audio.currentTime = 0; });

    // ── Play / Pause button ──────────────────────────────────────────────────
    playBtn.addEventListener('click', () => {
      if (audio.paused) audio.play();
      else audio.pause();
    });

    // ── Volume ───────────────────────────────────────────────────────────────
    const VOL_HIGH = 'M3 9v6h4l5 5V4L7 9H3zm13.5 3A4.5 4.5 0 0014 7.97v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z';
    const VOL_LOW  = 'M18.5 12A4.5 4.5 0 0016 7.97v8.05c1.48-.73 2.5-2.25 2.5-4.02zM5 9v6h4l5 5V4L9 9H5z';
    const VOL_MUTE = 'M16.5 12A4.5 4.5 0 0014 7.97v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z';

    volSlider.addEventListener('input', () => {
      audio.volume = volSlider.value;
      const v = parseFloat(volSlider.value);
      volPath.setAttribute('d', v === 0 ? VOL_MUTE : v < 0.5 ? VOL_LOW : VOL_HIGH);
    });

    volIcon.addEventListener('click', () => {
      if (audio.volume > 0) { audio.volume = 0; volSlider.value = 0; volPath.setAttribute('d', VOL_MUTE); }
      else { audio.volume = 1; volSlider.value = 1; volPath.setAttribute('d', VOL_HIGH); }
    });

    // ── Autoplay ─────────────────────────────────────────────────────────────
    audio.play().catch(() => {}); // browser may block autoplay; ignore silently
  </script>
</body>
</html>
    function supportsOpusPlayback() {
      return !!(audio.canPlayType('audio/webm; codecs="opus"') || audio.canPlayType('audio/ogg; codecs="opus"'));
    }

    function resolveSource() {
      const token = audio.dataset.token;
      const codec = audio.dataset.codec;
      const needsMp3Fallback = (codec === 'opus' || codec === 'opus_live') && !supportsOpusPlayback();
      return needsMp3Fallback ? `/stream/${token}?transcode=mp3` : `/stream/${token}`;
    }

    audio.src = resolveSource();
