<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title><%= sharedLink.name %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container" style="max-width:1080px; padding-bottom:100px;">
    <div style="padding-top:2.5rem; margin-bottom:1.5rem;">
      <h1 style="font-size:1.6rem; margin-bottom:0.25rem;"><%= sharedLink.name %></h1>
      <p class="text-muted text-sm" style="margin:0;"><%= playlists.length %> playlist<%= playlists.length !== 1 ? 's' : '' %> disponible<%= playlists.length !== 1 ? 's' : '' %></p>
    </div>

    <div class="layout" style="grid-template-columns:280px 1fr;">
      <div class="sidebar">
        <div class="card">
          <div class="card-title">Playlists</div>
          <ul class="folder-list">
            <% playlists.forEach(playlist => { %>
              <li>
                <a href="#" class="shared-playlist-link <%= selectedPlaylistId === playlist.id ? 'active' : '' %>" data-playlist-id="<%= playlist.id %>">
                  <span style="flex:1;"><%= playlist.name %></span>
                  <span class="text-muted text-sm"><%= playlist.files.length %></span>
                </a>
              </li>
            <% }) %>
          </ul>
        </div>
      </div>

      <div class="main">
        <% playlists.forEach(playlist => { %>
          <div class="card shared-playlist-panel" data-playlist-panel="<%= playlist.id %>" style="<%= selectedPlaylistId === playlist.id ? '' : 'display:none;' %>">
            <div style="display:flex; align-items:center; justify-content:space-between; gap:1rem; margin-bottom:1rem; flex-wrap:wrap;">
              <div>
                <div class="card-title" style="margin-bottom:.25rem;"><%= playlist.name %></div>
                <p class="text-muted text-sm" style="margin:0;"><%= playlist.files.length %> piste<%= playlist.files.length !== 1 ? 's' : '' %></p>
              </div>
            </div>

            <% if (!playlist.files.length) { %>
              <p class="text-muted">Cette playlist ne contient aucune piste disponible.</p>
            <% } else { %>
              <ul class="track-list">
                <% playlist.files.forEach((f, idx) => { %>
                  <li class="track-item track-item-public" data-sc-token="<%= f.share_token %>" onclick="scPlay('<%= f.share_token %>')">
                    <button class="track-play-inline" tabindex="-1">
                      <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                    </button>
                    <span class="track-num"><%= idx + 1 %></span>
                    <div class="track-info">
                      <span class="track-name"><%= f.title_tag || f.original_name.replace(/\.[^.]+$/, '') %></span>
                      <% if (f.artist) { %><span class="track-artist text-muted text-sm"><%= f.artist %></span><% } %>
                      <span class="track-meta">
                        <% if (f.duration) { %><%= Math.floor(f.duration / 60) %>:<%= String(Math.floor(f.duration % 60)).padStart(2,'0') %> · <% } %>
                        <%= (f.size / 1048576).toFixed(1) %> Mo
                      </span>
                    </div>
                    <% if (playlist.allow_download) { %>
                      <a href="/download/<%= f.share_token %>" class="copy-btn" style="flex-shrink:0;" title="Télécharger" onclick="event.stopPropagation();">↓</a>
                    <% } %>
                  </li>
                <% }) %>
              </ul>
            <% } %>
          </div>
        <% }) %>
      </div>
    </div>
  </div>

  <%- include('partials/audio-player') %>

  <script>
    scRegisterTracks([
      <% const tracks = playlists.flatMap(playlist => playlist.files.map(f => ({ playlist, file: f }))); %>
      <% tracks.forEach((entry, i) => { %>
        { token: '<%= entry.file.share_token %>', name: '<%= (entry.file.title_tag || entry.file.original_name).replace(/'/g, "\\'").replace(/\.[^.]+$/,'') %>', playlistName: '<%= entry.playlist.name.replace(/'/g, "\\'") %>', codec: '<%= entry.file.codec || "none" %>'<% if (entry.file.artist) { %>, artist: '<%= entry.file.artist.replace(/'/g, "\\'") %>'<% } %> }<%= i < tracks.length - 1 ? ',' : '' %>
      <% }) %>
    ]);

    const playlistLinks = document.querySelectorAll('.shared-playlist-link');
    const playlistPanels = document.querySelectorAll('[data-playlist-panel]');

    function showPlaylist(id) {
      playlistLinks.forEach(link => link.classList.toggle('active', Number(link.dataset.playlistId) === id));
      playlistPanels.forEach(panel => {
        panel.style.display = Number(panel.dataset.playlistPanel) === id ? '' : 'none';
      });
      history.replaceState(null, '', `${location.pathname}?playlist=${id}`);
    }

    playlistLinks.forEach(link => {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        showPlaylist(Number(link.dataset.playlistId));
      });
    });

    <% const firstTrack = tracks[0]; %>
    <% if (firstTrack) { %>
      scPlay('<%= firstTrack.file.share_token %>');
    <% } %>
  </script>
</body>
</html>
