<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title><%= playlist.name %></title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="container" style="max-width:680px; padding-bottom:100px;">
    <div style="padding-top:2.5rem; margin-bottom:1.5rem;">
      <h1 style="font-size:1.5rem; margin-bottom:0.25rem;"><%= playlist.name %></h1>
      <div style="display:flex; align-items:center; gap:.75rem; flex-wrap:wrap;">
        <p class="text-muted text-sm" style="margin:0;"><%= files.length %> piste<%= files.length!==1?'s':'' %></p>
        <a href="/playlist/<%= playlist.share_token %>/rss" class="copy-btn" style="font-size:.75rem;" title="Flux RSS / Podcast">RSS</a>
      </div>
    </div>

    <% if (!files.length) { %>
      <div class="card"><p class="text-muted">Cette playlist ne contient aucune piste audio.</p></div>
    <% } else { %>
      <ul class="track-list" id="trackList">
        <% files.forEach((f, idx) => { %>
          <li class="track-item track-item-public" data-sc-token="<%= f.share_token %>"
              onclick="scPlay('<%= f.share_token %>')">
            <button class="track-play-inline" tabindex="-1">
              <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
            </button>
            <span class="track-num"><%= idx + 1 %></span>
            <div class="track-info">
              <span class="track-name"><%= f.title_tag || f.original_name.replace(/\.[^.]+$/, '') %></span>
              <% if (f.artist) { %><span class="track-artist text-muted text-sm"><%= f.artist %></span><% } %>
              <span class="track-meta">
                <% if (f.duration) { %><%= Math.floor(f.duration/60) %>:<%= String(Math.floor(f.duration%60)).padStart(2,'0') %> · <% } %>
                <%= (f.size/1048576).toFixed(1) %> Mo
              </span>
            </div>
            <% if (playlist.allow_download) { %>
            <a href="/download/<%= f.share_token %>" class="copy-btn" style="flex-shrink:0;" title="Télécharger" onclick="event.stopPropagation();">↓</a>
            <% } %>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </div>

  <%- include('partials/audio-player') %>

  <script>
    scRegisterTracks([
      <% files.forEach((f, i) => { %>
        { token: '<%= f.share_token %>', name: '<%= (f.title_tag || f.original_name).replace(/'/g, "\\'").replace(/\.[^.]+$/,'') %>', playlistName: '<%= playlist.name.replace(/'/g, "\\'") %>', codec: '<%= f.codec || "none" %>'<% if (f.artist) { %>, artist: '<%= f.artist.replace(/'/g, "\\'") %>'<% } %> }<%= i < files.length - 1 ? ',' : '' %>
      <% }) %>
    ]);

    // Auto-play first track on load
    <% if (files.length) { %>
      scPlay('<%= files[0].share_token %>');
    <% } %>
  </script>
</body>
</html>
