<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= playlist.name %></title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body { margin:0; background:#1a1a2e; color:#e2e8f0; font-family:system-ui,sans-serif; }
    .embed-wrap { display:flex; flex-direction:column; height:100vh; overflow:hidden; }
    .embed-header { padding:.75rem 1rem; border-bottom:1px solid rgba(255,255,255,.08); }
    .embed-title { font-size:.95rem; font-weight:600; margin:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .embed-meta { font-size:.75rem; color:#94a3b8; margin:.1rem 0 0; }
    .embed-tracks { flex:1; overflow-y:auto; padding:.25rem 0; }
    .embed-track { display:flex; align-items:center; gap:.75rem; padding:.4rem 1rem; cursor:pointer; transition:background .15s; }
    .embed-track:hover, .embed-track.sc-active { background:rgba(255,255,255,.06); }
    .embed-num { font-size:.75rem; color:#94a3b8; min-width:1.2rem; text-align:right; }
    .embed-name { flex:1; font-size:.85rem; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .embed-dur  { font-size:.75rem; color:#94a3b8; }
    .embed-footer { padding:.4rem 1rem; border-top:1px solid rgba(255,255,255,.08); display:flex; justify-content:flex-end; }
    .embed-footer a { font-size:.75rem; color:#94a3b8; text-decoration:none; }
    .embed-footer a:hover { color:#e2e8f0; }
  </style>
</head>
<body>
  <div class="embed-wrap">
    <div class="embed-header">
      <p class="embed-title"><%= playlist.name %></p>
      <p class="embed-meta"><%= files.length %> piste<%= files.length!==1?'s':'' %></p>
    </div>

    <div class="embed-tracks">
      <% files.forEach((f, i) => { %>
        <div class="embed-track" data-sc-token="<%= f.share_token %>" onclick="scPlay('<%= f.share_token %>')">
          <span class="embed-num"><%= i+1 %></span>
          <span class="embed-name"><%= f.title_tag || f.original_name.replace(/\.[^.]+$/,'') %></span>
          <% if (f.duration) { %>
            <span class="embed-dur"><%= Math.floor(f.duration/60) %>:<%= String(Math.floor(f.duration%60)).padStart(2,'0') %></span>
          <% } %>
        </div>
      <% }) %>
    </div>

    <div class="embed-footer">
      <a href="/playlist/<%= locals.token || '' %>" target="_blank">Ouvrir dans AudioBoard ↗</a>
    </div>
  </div>

  <%- include('partials/audio-player') %>

  <script>
    scRegisterTracks([
      <% files.forEach((f, i) => { %>
        { token: '<%= f.share_token %>', name: '<%= (f.title_tag || f.original_name).replace(/'/g, "\\'").replace(/\.[^.]+$/,'') %>', playlistName: '<%= playlist.name.replace(/'/g, "\\'") %>', codec: '<%= f.codec || "none" %>' }<%= i < files.length-1 ? ',' : '' %>
      <% }) %>
    ]);
    <% if (files.length) { %>scPlay('<%= files[0].share_token %>'); <% } %>
  </script>
</body>
</html>
