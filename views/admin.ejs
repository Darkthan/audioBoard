<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AudioBoard - Administration</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <div class="container">
    <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>

    <!-- Stats -->
    <div class="stats-grid">
      <div class="stat-card"><div class="stat-value"><%= stats.totalFiles %></div><div class="stat-label">Fichiers</div></div>
      <div class="stat-card"><div class="stat-value"><%= (stats.totalSize/1048576).toFixed(1) %> Mo</div><div class="stat-label">Espace utilisé</div></div>
      <div class="stat-card"><div class="stat-value"><%= stats.totalUsers %></div><div class="stat-label">Utilisateurs</div></div>
      <div class="stat-card"><div class="stat-value"><%= stats.totalPlaylists %></div><div class="stat-label">Playlists</div></div>
      <div class="stat-card"><div class="stat-value"><%= stats.playsToday %></div><div class="stat-label">Écoutes aujourd'hui</div></div>
    </div>


    <!-- Paramètres -->
    <div class="card" style="margin-bottom:1.5rem;">
      <div class="card-title">Paramètres</div>
        <form method="POST" action="/admin/settings">
          <div class="form-group">
            <label>Codec de compression</label>
            <div style="display:flex; flex-direction:column; gap:.5rem; margin-top:.25rem;">
              <% [
                  {
                    val:'none',
                    label:'Aucun — fichier original conservé',
                    info:'Le serveur garde le fichier tel quel et le diffuse sans conversion. A utiliser si vous voulez preserver strictement la source ou eviter toute charge CPU.'
                  },
                  {
                    val:'mp3',
                    label:'MP3 — compatibilité universelle',
                    info:'Le serveur convertit le fichier en MP3 des l\'upload. Bon choix si vous voulez la lecture la plus simple possible sur presque tous les appareils.'
                  },
                  {
                    val:'aac',
                    label:'AAC — bonne qualité, compatible iOS/Safari, cache P2P',
                    info:'Le serveur encode en AAC a l\'upload. Bon compromis si vous voulez un format moderne, tres compatible web/mobile et partageable en cache P2P.'
                  },
                  {
                    val:'opus',
                    label:'Opus — meilleure qualité/taille, cache P2P (pré-encodé)',
                    info:'Le serveur stocke uniquement une version Opus pre-encodee. A privilegier pour reduire la taille et activer le P2P, avec fallback MP3 live sur les appareils non compatibles.'
                  },
                  {
                    val:'opus_live',
                    label:'Opus live — transcoding à la volée (sans cache P2P)',
                    info:'Le serveur conserve la source puis reencode en Opus a chaque lecture. Utile pour economiser le stockage, mais plus couteux pour le serveur et sans cache P2P.'
                  },
                ].forEach(c => { %>
                <label style="display:flex; align-items:center; gap:.5rem; cursor:pointer;">
                  <input type="radio" name="compression_codec" value="<%= c.val %>"
                         <%= (settings.compression_codec||'mp3')===c.val?'checked':'' %>
                         onchange="updateBitrates(this.value)">
                  <span><%= c.label %></span>
                  <span class="info-dot" tabindex="0" aria-label="Informations sur <%= c.label %>">
                    i
                    <span class="info-tooltip"><%= c.info %></span>
                  </span>
                </label>
              <% }) %>
            </div>
          </div>
          <div class="form-group" id="bitrate-group">
            <label for="compression_bitrate">Bitrate (kbps)</label>
            <select name="compression_bitrate" id="compression_bitrate" class="form-control">
            </select>
          </div>
          <div class="form-group">
            <label style="display:flex; align-items:center; gap:.5rem; cursor:pointer;">
              <input type="checkbox" name="webrtc_enabled" value="1" <%= (settings.webrtc_enabled!=='0')?'checked':'' %>>
              Activer le cache P2P WebRTC (partage entre navigateurs)
            </label>
            <p class="text-muted text-sm" style="margin:.25rem 0 0 1.4rem;">Désactiver si WebRTC est bloqué sur votre réseau. Sans effet sur les fichiers Opus live.</p>
          </div>

          <hr style="border:none; border-top:1px solid var(--border); margin:1.25rem 0;">

          <div class="form-group">
            <label style="display:flex; align-items:center; gap:.5rem; cursor:pointer;">
              <input type="checkbox" name="passwordless_enabled" value="1" <%= (settings.passwordless_enabled==='1')?'checked':'' %>>
              Activer la connexion par lien email (magic link)
            </label>
            <p class="text-muted text-sm" style="margin:.25rem 0 0 1.4rem;">Les utilisateurs peuvent se connecter sans mot de passe si leur email est renseigné.</p>
          </div>

          <div class="card-title" style="font-size:.85rem; margin:1rem 0 .5rem; color:var(--text-muted);">Configuration SMTP (pour l'envoi des magic links)</div>
          <div style="display:grid; grid-template-columns:1fr 120px; gap:.5rem;">
            <div class="form-group" style="margin:0;">
              <label style="font-size:.8rem;">Serveur SMTP</label>
              <input type="text" name="smtp_host" class="form-control" value="<%= settings.smtp_host || '' %>" placeholder="smtp.example.com">
            </div>
            <div class="form-group" style="margin:0;">
              <label style="font-size:.8rem;">Port</label>
              <input type="number" name="smtp_port" class="form-control" value="<%= settings.smtp_port || '587' %>">
            </div>
          </div>
          <div style="display:grid; grid-template-columns:1fr 1fr; gap:.5rem; margin-top:.5rem;">
            <div class="form-group" style="margin:0;">
              <label style="font-size:.8rem;">Utilisateur SMTP</label>
              <input type="text" name="smtp_user" class="form-control" value="<%= settings.smtp_user || '' %>" autocomplete="off">
            </div>
            <div class="form-group" style="margin:0;">
              <label style="font-size:.8rem;">Mot de passe SMTP</label>
              <input type="password" name="smtp_pass" class="form-control" value="<%= settings.smtp_pass || '' %>" autocomplete="new-password">
            </div>
          </div>
          <div style="display:grid; grid-template-columns:1fr auto; gap:.5rem; margin-top:.5rem; align-items:end;">
            <div class="form-group" style="margin:0;">
              <label style="font-size:.8rem;">Adresse expéditeur</label>
              <input type="email" name="smtp_from" class="form-control" value="<%= settings.smtp_from || '' %>" placeholder="audioboard@example.com">
            </div>
            <div class="form-group" style="margin:0;">
              <label style="display:flex; align-items:center; gap:.4rem; cursor:pointer; font-size:.8rem; padding-bottom:.4rem;">
                <input type="checkbox" name="smtp_secure" value="1" <%= (settings.smtp_secure==='1')?'checked':'' %>>
                TLS (port 465)
              </label>
            </div>
          </div>
          <div class="form-group">
            <label for="retention_days">Conservation des fichiers (jours)</label>
            <input type="number" name="retention_days" id="retention_days" class="form-control"
                   value="<%= settings.retention_days %>" min="1" max="3650">
          </div>
          <div class="form-group">
            <label for="empty_playlist_retention_days">Suppression des playlists vides après (jours)</label>
            <input type="number" name="empty_playlist_retention_days" id="empty_playlist_retention_days" class="form-control"
                   value="<%= settings.empty_playlist_retention_days || '0' %>" min="0" max="3650">
            <p class="text-muted text-sm" style="margin:.25rem 0 0;">
              Une playlist vide de toute piste sera supprimée automatiquement après ce délai.
              <strong>0</strong> = désactivé (les playlists vides sont conservées indéfiniment).
            </p>
          </div>

          <hr style="border:none; border-top:1px solid var(--border); margin:1.25rem 0;">

          <div class="form-group">
            <label style="display:flex; align-items:center; gap:.5rem; cursor:pointer;">
              <input type="checkbox" name="webauthn_enabled" value="1" <%= (settings.webauthn_enabled==='1')?'checked':'' %>>
              Activer l'authentification par clé d'accès (WebAuthn / Passkeys)
            </label>
            <p class="text-muted text-sm" style="margin:.25rem 0 0 1.4rem;">Les utilisateurs peuvent se connecter sans mot de passe avec leur appareil (Touch ID, Face ID, clé FIDO2…).</p>
          </div>

          <div class="card-title" style="font-size:.85rem; margin:1rem 0 .5rem; color:var(--text-muted);">Configuration WebAuthn</div>
          <div style="display:grid; grid-template-columns:1fr 1fr; gap:.5rem;">
            <div class="form-group" style="margin:0;">
              <label style="font-size:.8rem;">RP ID <span class="text-muted">(domaine)</span></label>
              <input type="text" name="webauthn_rp_id" class="form-control" value="<%= settings.webauthn_rp_id || '' %>"
                     placeholder="ex : audioboard.monentreprise.com">
              <p class="text-muted text-sm" style="margin:.3rem 0 0;">
                Le nom de domaine exact utilisé dans l'URL du navigateur (<strong>sans</strong> http:// ni port).<br>
                Exemples&nbsp;: <code>audioboard.monentreprise.com</code>, <code>monserveur.local</code>, <code>localhost</code>.<br>
                ⚠️ Les adresses IP ne sont pas acceptées par WebAuthn.<br>
                <strong>Laisser vide</strong> = utilise automatiquement le domaine de la requête (recommandé si un seul domaine).
              </p>
            </div>
            <div class="form-group" style="margin:0;">
              <label style="font-size:.8rem;">RP Name <span class="text-muted">(nom affiché)</span></label>
              <input type="text" name="webauthn_rp_name" class="form-control" value="<%= settings.webauthn_rp_name || 'AudioBoard' %>"
                     placeholder="AudioBoard">
              <p class="text-muted text-sm" style="margin:.3rem 0 0;">
                Nom affiché par le navigateur lors de l'enregistrement ou de l'utilisation d'une clé d'accès.<br>
                Exemple&nbsp;: <code>AudioBoard — Mon Entreprise</code>.<br>
                Valeur par défaut&nbsp;: <code>AudioBoard</code>.
              </p>
            </div>
          </div>

          <button type="submit" class="btn btn-primary" style="margin-top:1rem;">Sauvegarder</button>
        </form>
    </div>

    <div class="admin-grid">
      <!-- Utilisateurs -->
      <div class="card" style="grid-column: 1 / -1;">
        <div class="card-title">Utilisateurs</div>
        <form method="POST" action="/admin/users" class="inline-form" style="margin-bottom:1rem;">
          <div class="form-group">
            <input type="text" name="username" class="form-control" placeholder="Nom d'utilisateur" required>
          </div>
          <div class="form-group">
            <input type="password" name="password" class="form-control" placeholder="Mot de passe" required>
          </div>
          <div class="form-group">
            <input type="email" name="email" class="form-control" placeholder="Email (optionnel, pour magic link)">
          </div>
          <div class="form-group">
            <select name="role" class="form-control">
              <option value="uploader">Uploader</option>
              <option value="admin">Admin</option>
            </select>
          </div>
          <button type="submit" class="btn btn-primary btn-sm">Créer</button>
        </form>
        <div class="table-wrap">
          <table class="admin-users-table">
            <thead><tr><th>Utilisateur</th><th>Email</th><th>Rôle</th><th>Stockage</th><th>Quota (Mo)</th><th>Mot de passe</th><th>Créé le</th><th></th></tr></thead>
            <tbody>
              <% users.forEach(u => {
                 const usedMb = (u.storage_used / 1048576).toFixed(1);
                 const quotaMb = u.quota_mb || 0;
                 const pct = quotaMb > 0 ? Math.min(100, Math.round(u.storage_used / (quotaMb * 1048576) * 100)) : 0;
              %>
                <tr class="admin-user-row" data-user-row>
                  <td><%= u.username %></td>
                  <td>
                    <form id="user-update-<%= u.id %>" method="POST" action="/admin/users/<%= u.id %>/update" class="admin-cell-form">
                      <input type="email" name="email" value="<%= u.email || '' %>" placeholder="—"
                             class="form-control admin-cell-input user-edit-field" style="font-size:.8rem; padding:.2rem .5rem; height:auto; min-width:160px;" disabled>
                    </form>
                  </td>
                  <td><span class="badge badge-<%= u.role %>"><%= u.role %></span></td>
                  <td style="white-space:nowrap;">
                    <span class="text-muted text-sm"><%= usedMb %> Mo</span>
                    <% if (quotaMb > 0) { %>
                    <div style="background:var(--border); border-radius:3px; height:4px; width:80px; margin-top:3px;">
                      <div style="width:<%= pct %>%; background:<%= pct>=90?'var(--danger)':pct>=70?'var(--warning)':'var(--primary)' %>; height:100%; border-radius:3px;"></div>
                    </div>
                    <% } %>
                  </td>
                  <td>
                    <div class="admin-cell-form">
                      <input type="number" name="quota_mb" value="<%= quotaMb || '' %>" placeholder="∞" min="1"
                             class="form-control admin-cell-input admin-cell-input-small user-edit-field" style="font-size:.8rem; padding:.2rem .5rem; height:auto; width:80px;" form="user-update-<%= u.id %>" disabled>
                    </div>
                  </td>
                  <td>
                    <input type="password" name="new_password" placeholder="Nouveau mdp"
                           class="form-control admin-cell-input user-edit-field" style="font-size:.8rem; padding:.2rem .5rem; height:auto; min-width:130px;" form="user-update-<%= u.id %>" disabled autocomplete="new-password">
                  </td>
                  <td class="text-muted"><%= new Date(u.created_at).toLocaleDateString('fr-FR') %></td>
                  <td>
                    <button type="button" class="icon-btn user-edit-btn" data-user-edit aria-label="Modifier l'utilisateur">✎</button>
                    <button type="submit" class="btn btn-secondary btn-sm user-save-btn" form="user-update-<%= u.id %>" hidden>Enregistrer</button>
                    <% if (u.id !== user.id) { %>
                      <form method="POST" action="/admin/users/<%= u.id %>/delete" style="display:inline;"
                            onsubmit="return confirm('Supprimer cet utilisateur et toutes ses playlists ?')">
                        <button type="submit" class="btn btn-danger btn-sm">Suppr.</button>
                      </form>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="card shared-links-section span-full">
        <div class="card-title">Liens permanents multi-playlists</div>
        <form method="POST" action="/admin/shared-links" class="shared-link-create vertical">
          <div class="form-group">
            <label for="shared_link_name">Nom du lien</label>
            <input type="text" id="shared_link_name" name="name" class="form-control" placeholder="Ex. Médiathèque clients" required>
          </div>
          <div class="form-group">
            <label for="shared_link_filter">Filtrer les playlists</label>
            <input type="text" id="shared_link_filter" class="form-control shared-playlist-filter" placeholder="Rechercher par nom">
          </div>
          <div class="form-group">
            <label class="text-muted text-sm">Sélection des playlists</label>
            <div class="playlist-checkboxes multi-select">
              <% playlists.forEach(p => { %>
                <label class="playlist-checkbox" data-name="<%= p.name.toLowerCase() %>">
                  <input type="checkbox" name="playlist_ids" value="<%= p.id %>">
                  <div class="playlist-checkbox-text">
                    <span class="checkbox-title"><%= p.name %></span>
                    <span class="checkbox-meta">Propriétaire · <%= p.owner_name %> · créé le <%= new Date(p.created_at).toLocaleDateString('fr-FR') %></span>
                  </div>
                </label>
              <% }) %>
            </div>
          </div>
          <button type="submit" class="btn btn-primary btn-sm create-link-btn">Créer le lien</button>
        </form>

        <% if (!sharedLinks.length) { %>
          <p class="text-muted">Aucun lien permanent créé pour l'instant.</p>
        <% } else { %>
          <div class="shared-link-list">
            <% sharedLinks.forEach(link => { %>
              <div class="shared-link-list-item">
                <div>
                  <div class="card-title" style="margin-bottom:.25rem;"><%= link.name %></div>
                  <p class="text-muted text-sm" style="margin:0;">
                    <%= link.playlists.length %> playlist<%= link.playlists.length !== 1 ? 's' : '' %> · créé le <%= new Date(link.created_at).toLocaleDateString('fr-FR') %>
                  </p>
                  <p class="text-muted text-sm link-token">/l/<%= link.token %></p>
                </div>
                <div class="shared-link-actions">
                  <button type="button" class="copy-btn" onclick="copySharedLink('<%= link.token %>')">Copier</button>
                  <button type="button" class="icon-btn edit-link-btn" data-target="link-<%= link.id %>">✎</button>
                  <form method="POST" action="/admin/shared-links/<%= link.id %>/delete" onsubmit="return confirm('Supprimer ce lien permanent ?')">
                    <button type="submit" class="btn btn-danger btn-sm">Suppr.</button>
                  </form>
                </div>
                <form method="POST" action="/admin/shared-links/<%= link.id %>/update" class="shared-link-form" id="link-<%= link.id %>">
                  <input type="text" placeholder="Rechercher des playlists" class="form-control shared-playlist-search" aria-label="Recherche playlists">
                  <div class="playlist-checkboxes multi-select">
                    <% playlists.forEach(p => { %>
                      <label class="playlist-checkbox" data-name="<%= p.name.toLowerCase() %>">
                        <input type="checkbox" name="playlist_ids" value="<%= p.id %>" <%= link.playlist_ids.includes(p.id) ? 'checked' : '' %>>
                        <div class="playlist-checkbox-text">
                          <span class="checkbox-title"><%= p.name %></span>
                          <span class="checkbox-meta">Propriétaire · <%= p.owner_name %> · créé le <%= new Date(p.created_at).toLocaleDateString('fr-FR') %></span>
                        </div>
                      </label>
                    <% }) %>
                  </div>
                  <button type="submit" class="btn btn-primary btn-sm">Sauvegarder</button>
                </form>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>

      <!-- Toutes les playlists -->
      <div class="card" style="grid-column: 1 / -1;">
        <div class="card-title">Toutes les playlists</div>
        <% if (!playlists.length) { %>
          <p class="text-muted">Aucune playlist créée.</p>
        <% } else { %>
          <div class="table-wrap">
            <table>
              <thead><tr><th>Playlist</th><th>Propriétaire</th><th>Fichiers</th><th>Créée le</th><th>Lien public</th><th></th></tr></thead>
              <tbody>
                <% playlists.forEach(p => { %>
                  <tr>
                    <td><%= p.name %></td>
                    <td class="text-muted"><%= p.owner_name %></td>
                    <td class="text-muted"><%= p.file_count %></td>
                    <td class="text-muted"><%= new Date(p.created_at).toLocaleDateString('fr-FR') %></td>
                    <td>
                      <% if (p.share_token) { %>
                        <button class="copy-btn" onclick="copyPlaylistLink('<%= p.share_token %>')">Copier</button>
                        <form method="POST" action="/playlists/<%= p.id %>/revoke" style="display:inline;">
                          <button type="submit" class="copy-btn" style="color:var(--warning);">Révoquer</button>
                        </form>
                      <% } else { %>
                        <form method="POST" action="/playlists/<%= p.id %>/share" style="display:inline;">
                          <button type="submit" class="copy-btn" style="color:var(--primary);">Générer</button>
                        </form>
                      <% } %>
                    </td>
                    <td>
                      <form method="POST" action="/admin/playlists/<%= p.id %>/delete" style="display:inline;"
                            onsubmit="return confirm('Supprimer la playlist « <%= p.name %> » et tous ses fichiers ?')">
                        <button type="submit" class="btn btn-danger btn-sm">Suppr.</button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <script>
    function copyPlaylistLink(token) {
      navigator.clipboard.writeText(location.origin + '/playlist/' + token).then(() => alert('Lien copié !'));
    }
    function copySharedLink(token) {
      navigator.clipboard.writeText(location.origin + '/l/' + token).then(() => alert('Lien copié !'));
    }
    const filterInput = document.querySelector('.shared-playlist-filter');
    const playlistLabels = document.querySelectorAll('.playlist-checkbox');
    function applyPlaylistFilter(term) {
      playlistLabels.forEach(label => {
        const matches = !term || label.dataset.name.includes(term);
        label.style.display = matches ? '' : 'none';
      });
    }
    if (filterInput) {
      filterInput.addEventListener('input', () => {
        applyPlaylistFilter(filterInput.value.trim().toLowerCase());
      });
    }
    document.querySelectorAll('.edit-link-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.shared-link-list-item');
        if (!item) return;
        const form = item.querySelector('.shared-link-form');
        if (!form) return;
        item.classList.toggle('shared-link-card--editing');
        if (item.classList.contains('shared-link-card--editing')) {
          form.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });
    let currentEditingRow = null;
    document.querySelectorAll('[data-user-edit]').forEach(btn => {
      btn.addEventListener('click', () => {
        const row = btn.closest('[data-user-row]');
        if (!row) return;
        const isEditing = row !== currentEditingRow;

        if (currentEditingRow && currentEditingRow !== row) {
          currentEditingRow.classList.remove('admin-user-row--editing');
          currentEditingRow.querySelectorAll('.user-edit-field').forEach(f => { f.disabled = true; });
          const prevSave = currentEditingRow.querySelector('.user-save-btn');
          if (prevSave) prevSave.hidden = true;
        }

        row.classList.toggle('admin-user-row--editing', isEditing);
        row.querySelectorAll('.user-edit-field').forEach(f => { f.disabled = !isEditing; });
        const saveBtn = row.querySelector('.user-save-btn');
        if (saveBtn) saveBtn.hidden = !isEditing;
        btn.setAttribute('aria-pressed', String(isEditing));
        currentEditingRow = isEditing ? row : null;

        if (isEditing) {
          const first = row.querySelector('.user-edit-field');
          if (first) { first.focus(); first.select(); }
        }
      });
    });

    const OPUS_BR = ['32','48','64','96','128','160','192'];
    const BITRATES = {
      none:     [],
      mp3:      ['64','96','128','160','192','256','320'],
      aac:      ['64','96','128','160','192','256'],
      opus:     OPUS_BR,
      opus_live:OPUS_BR,
    };
    const currentBitrate = '<%= settings.compression_bitrate || "128" %>';

    function updateBitrates(codec) {
      const sel = document.getElementById('compression_bitrate');
      const group = document.getElementById('bitrate-group');
      const list = BITRATES[codec] || [];
      group.style.display = list.length ? '' : 'none';
      sel.innerHTML = list.map(b =>
        `<option value="${b}"${b === currentBitrate ? ' selected' : ''}>${b} kbps</option>`
      ).join('');
    }

    // Init on page load
    const checkedCodec = document.querySelector('[name=compression_codec]:checked');
    if (checkedCodec) updateBitrates(checkedCodec.value);
  </script>
</body>
</html>
